# Railway 環境變數設定檔案
# 複製到 Railway 嘅環境變數設定

# VNC 服務配置
VNC_PASSWORD=your_secure_password_here
VNC_RESOLUTION=1280x720
VNC_DEPTH=24
VNC_DISPLAY=:1

# 服務啟動配置
SERVICE_NAME=vnc-server
SERVICE_PORT=5901
SERVICE_COMMAND=vncserver :1 -geometry 1280x720 -depth 24

# 預設啟動指令
STARTUP_COMMAND=./railway_vnc_setup.sh