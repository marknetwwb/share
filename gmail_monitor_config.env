# Gmail 訂單監控配置
# 用於 OpenClaw 自動化系統

## 📧 Gmail 配置
GMAIL_USERNAME=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password
GMAIL_LABEL=訂單

## 📱 Telegram 配置
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_GROUP_ID=your_group_chat_id
TELEGRAM_GROUP_NAME=ACS BOOKING REQUEST

## ⚙️ 監控頻率
MONITOR_INTERVAL=5  # 分鐘
MONITOR_FREQUENCY=hourly  # hourly, daily

## 📊 日誌配置
LOG_LEVEL=INFO
LOG_FILE=/data/workspace/gmail_monitor.log

## 🔍 監控關鍵字
KEYWORDS=JOB ID,Number of Passengers,Service Date,Service Time

## ⏰ 定時執行時間
DAILY_CHECK_TIME=09:00
HOURLY_CHECK_ENABLED=true